font-family = "JetBrains Mono"

# Remove titlebar
window-decoration = auto
macos-titlebar-style = hidden

# Window padding
window-padding-x = 8
window-padding-y = 8

theme = catppuccin-mocha

# Otherwise selections become invisible.
cursor-text = black
cursor-color = #f5e0dc

# Miscellaneous
quit-after-last-window-closed = true
mouse-hide-while-typing = true
