[user]
    name = Basile Dura
    email = basile@bdura.me
    signingkey = /Users/basile/.ssh/id_ed25519_sign
[gpg]
    format = ssh
[commit]
    gpgsign = true
[core]
    excludesfile = /Users/basile/.global_gitignore
[pull]
    rebase = true
[push]
    default = current
    autoSetupRemote = true
[alias]
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
[status]
    showUntrackedFiles = all
[core]
    editor = nvim

